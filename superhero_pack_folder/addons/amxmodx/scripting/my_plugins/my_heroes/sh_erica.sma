#define I_WANT_CONSTANTS
#define I_WANT_QUICK_CHECKS
#define I_WANT_MISC_FUNCS
#include "../my_include/superheromod.inc"
#include "tranq_gun_inc/sh_erica_get_set.inc"
#include "tranq_gun_inc/sh_man_hook_funcs.inc"
#include "tranq_gun_inc/sh_tranq_funcs.inc"
#include "sh_aux_stuff/sh_aux_inc.inc"
#include "sh_aux_stuff/sh_aux_stuff_natives_pt1.inc"
#include "sh_aux_stuff/sh_aux_stuff_natives_pt5.inc"
#include "bleed_knife_inc/sh_bknife_fx.inc"
#include "custom_grenades/custom_grenades.inc"
#include "tranq_gun_inc/sh_molotov_fx.inc"
#include "../my_include/my_author_header.inc"
// GLOBAL VARIABLES

new gHeroID

stock const gHeroName[] = "Erica Fonseca"

new gNumDarts[SH_MAXSLOTS+1]
new g_erica_points[SH_MAXSLOTS+1]
new g_erica_kills[SH_MAXSLOTS+1]
new Float:g_base_er_speed[SH_MAXSLOTS+1]
new Float:g_normal_er_speed[SH_MAXSLOTS+1]
new Float:g_base_er_radius[SH_MAXSLOTS+1]
new Float:g_normal_er_radius[SH_MAXSLOTS+1]
new g_prevWeapon[SH_MAXSLOTS+1]



//new gHeroLevel
new pcvar_base_er_points
new pcvar_max_er_points
new pcvar_speed_speed_er_points_pct
new pcvar_speed_points_er_radius_pct
new pcvar_dmg_speed_er_points_pct
new pcvar_base_er_speed
new pcvar_max_er_speed
new pcvar_max_er_radius
new pcvar_base_er_radius
new pcvar_num_er_darts
new pcvar_num_mollies


//----------------------------------------------------------------------------------------------
public plugin_init()
{
	// Plugin Info
	register_plugin("SUPERHERO Erica", "1.0", AUTHOR)
	
	
	// DO NOT EDIT THIS FILE TO CHANGE CVARS, USE THE SHCONFIG.CFG
	create_cvar("erica_level", "8")
	pcvar_speed_points_er_radius_pct = create_cvar("erica_speed_points_radius_pct", "0.1")
	pcvar_base_er_radius = create_cvar("erica_base_radius", "500")
	pcvar_max_er_radius = create_cvar("erica_max_radius", "1000")
	pcvar_base_er_points = create_cvar("erica_base_points", "1000")
	pcvar_max_er_points = create_cvar("erica_max_points", "1000")
	pcvar_base_er_speed = create_cvar("erica_base_speed", "500")
	pcvar_max_er_speed = create_cvar("erica_max_speed", "1000")
	pcvar_num_er_darts = create_cvar("erica_num_darts", "100")
	pcvar_num_mollies = create_cvar("erica_num_mollies", "0")
	pcvar_speed_speed_er_points_pct = create_cvar("erica_speed_speed_points_pct", "0.1")
	pcvar_dmg_speed_er_points_pct = create_cvar("erica_dmg_speed_points_pct", "0.1")
	
	gHeroID=shCreateHero(gHeroName, "Erica!", "Grab attention by burning and bleeding and get fastaaa!", false, "erica_level" )
	
	RegisterHam(Ham_TraceAttack,"player","Erica_ham_trace_damage",_,true)
	
	sh_register_superheromod_weapon_model(gHeroID,CSW_KNIFE,NAVALHA_V_MODEL,NAVALHA_P_MODEL)
	sh_register_superheromod_weapon_model(gHeroID,CSW_ELITE,TRANQS_V_MODEL,TRANQS_P_MODEL)
	
	
	register_event("CurWeapon", "weaponChange", "be", "1=1")
	
	
}

public plugin_natives(){

	
	register_native("tranq_dec_num_darts","_tranq_dec_num_darts",0);
	register_native("tranq_get_num_darts","_tranq_get_num_darts",0);
	register_native("tranq_set_num_darts","_tranq_set_num_darts",0);
	
	
	register_native("tranq_get_hero_id","_tranq_get_hero_id",0);
	
	register_native("tranq_get_is_max_points","_tranq_get_is_max_points",0);
	

}
public bool:_tranq_get_is_max_points(iPlugin,iParams){

	new id= get_param(1)
	return g_erica_points[id]>=cvar_val(num, pcvar_max_er_points);


}

public _tranq_get_hero_id(iPlugin,iParams){
	return gHeroID
}
public _tranq_set_num_darts(iPlugin,iParams){
	new id= get_param(1)
	new value_to_set=get_param(2)
	gNumDarts[id]=value_to_set;
}
public _tranq_get_num_darts(iPlugin,iParams){


	new id= get_param(1)
	return gNumDarts[id]

}

public _tranq_dec_num_darts(iPlugin,iParams){


	new id= get_param(1)
	gNumDarts[id]-= (gNumDarts[id]>0)? 1:0

}

prepare_erica(id){

	g_erica_kills[id]=0;
	g_erica_points[id] = cvar_val(num, pcvar_base_er_points);
	g_base_er_speed[id] = cvar_val(float, pcvar_base_er_speed)
	g_base_er_radius[id] = cvar_val(float, pcvar_base_er_radius)
	g_normal_er_radius[id] = cvar_val(float, pcvar_base_er_radius)
	g_normal_er_speed[id]=0.0
	gNumDarts[id] = cvar_val(num, pcvar_num_er_darts)
}
//----------------------------------------------------------------------------------------------
public sh_hero_init(id, heroID, sh_init_mode:mode){
	if(heroID!=gHeroID) return

	if(sh_get_user_has_hero(id, gHeroID)){
		prepare_erica(id)
		Erica_weapons(id)
		
	}
	else{
		sh_reset_max_speed(id)
		g_erica_points[id]=0;
		g_erica_kills[id]=0;
		g_base_er_speed[id]=0.0
		g_base_er_radius[id]=0.0
		g_normal_er_radius[id]=0.0
		g_normal_er_speed[id]=0.0
		gNumDarts[id]=0
		if ( is_user_alive(id) ) {
			sh_drop_weapon(id, CSW_ELITE, true)
		}
		hook_set_hook(id,0)
	}
	
	
}

public Erica_ham_trace_damage(Victim, Attacker, Float:Damage, Float:Direction[3], Ptr, DamageBits)
{
	if ( !sh_is_active() || !is_user_alive(Victim)||!is_user_alive(Attacker)){

		return HAM_IGNORED
	}

	new my_hitpoint_enum:the_hitpoint= my_hitpoint_enum:get_tr2(Ptr,TR_Hitgroup)

	return do_bleed_knife_attack(Victim,Attacker,gHeroID,30,40,sh_get_user_has_hero(Attacker,gHeroID),_,_,_,1,the_hitpoint)


	
}
//----------------------------------------------------------------------------------------------
public sh_client_spawn(id)
{	
	if(sh_is_active()&&is_user_alive(id)){
		if ( sh_get_user_has_hero(id,gHeroID) ) {
			Erica_weapons(id)
			prepare_erica(id)
		}
	}
	
}
public client_disconnected(id){
	
	g_erica_points[id]=0;
	g_erica_kills[id]=0;
	g_base_er_speed[id]=0.0
	g_base_er_radius[id]=0.0
	g_normal_er_radius[id]=0.0
	g_normal_er_speed[id]=0.0
	gNumDarts[id]=0
	hook_set_hook(id,0)
}


public sh_round_start(){

	for(new id=1;id<sh_maxplayers()+1;id++){

		if(!is_user_alive(id)) return

		if ( sh_get_user_has_hero(id,gHeroID) ) {
			if(get_user_maxspeed(id)<g_base_er_speed[id]){
				set_user_maxspeed(id,g_base_er_speed[id])
			}
		}

	}
}
add_speed_points(id,Float:damage){
	
	g_erica_points[id]=min(cvar_val(num, pcvar_max_er_points),
				g_erica_points[id]+(floatround(damage*
					cvar_val(float, pcvar_dmg_speed_er_points_pct))))
	update_stats(id)
	
}
public sh_round_end(){

	remove_entity_name(DART_CLASSNAME)
}
public weaponChange(id)
{
	if (!sh_is_active()) return PLUGIN_CONTINUE
	if(!sh_get_user_has_hero(id,gHeroID) ) return PLUGIN_CONTINUE

	new wpnid = get_user_weapon(id)
	if ( g_prevWeapon[id] != wpnid ) {
		if ( (get_user_maxspeed(id) < g_normal_er_speed[id])&&!sh_get_stun(id)&&sh_is_inround()&&!sh_is_freezetime()){
			set_user_maxspeed(id, g_normal_er_speed[id])
		}
	}
	g_prevWeapon[id] = wpnid
	return PLUGIN_CONTINUE

}


update_stats(id){
	if(sh_get_user_has_hero(id,gHeroID) &&is_user_alive(id)){
		new Float:maxspeed=get_user_maxspeed(id)
		g_normal_er_speed[id]=floatmax(floatmin(floatadd(g_base_er_speed[id],floatmul(cvar_val(float, pcvar_speed_speed_er_points_pct),
						float(g_erica_points[id]))),cvar_val(float, pcvar_max_er_speed)),maxspeed),
		set_user_maxspeed(id,g_normal_er_speed[id])
		g_normal_er_radius[id]=floatmin(floatadd(g_base_er_radius[id],floatmul(float(g_erica_points[id]),cvar_val(float, pcvar_speed_points_er_radius_pct))),cvar_val(float, pcvar_max_er_radius));
			
	}


}
public Erica_weapons(id)
{
if ( sh_is_active() && sh_get_user_has_hero(id,gHeroID) &&is_user_alive(id)) {
	give_custom_grenades(id,GREN_MOLLY,cvar_val(num, pcvar_num_mollies))
	sh_give_weapon(id, CSW_ELITE,true)
	
	new weapon_id=get_weapon_ent_of_player(id,CSW_ELITE)
	if(is_valid_ent(weapon_id)){
		
		set_pdata_int(weapon_id, m_iClip, DART_PISTOL_CLIP_SIZE, XO_WEAPON);
		cs_set_user_bpammo(id, CSW_ELITE,gNumDarts[id]-DART_PISTOL_CLIP_SIZE);
	}
	hook_set_hook(id,1)
}
}

public sh_extra_damage_fwd_pre(&victim, &attacker, &damage,  &my_hitpoint_enum:bodypart,&sh_damage_mode:dmgMode, &sh_extra_damage_flags:sh_extra_dmg_flags, const Float:dmgOrigin[3],&dmg_type,&sh_thrash_brat_dmg_type:new_dmg_type, custom_weapon_id){
	
    if ( !sh_is_active() || !is_user_alive(victim) || !is_user_alive(attacker)){

        return DMG_FWD_PASS
    }
    if((new_dmg_type==SH_NEW_DMG_FIRE)||(new_dmg_type==SH_NEW_DMG_BLEED)){
        if((attacker!=victim) && sh_get_user_has_hero(attacker,gHeroID) ){
			aura(attacker,LineColors[PINK])
			add_speed_points(attacker,float(damage))
        }
    }

    return DMG_FWD_PASS
}
public sh_client_death(killed,killer)
{

	static killer_name[128]
	get_user_name(killer,killer_name,127)
	if(sh_get_user_has_hero(killer,gHeroID)&&(killed!=killer)){
		
		g_erica_kills[killer]++;
		sh_chat_message(0,gHeroID,"%s: WOW! AMAZING, HUH?!",killer_name)
	
	}
	
}
