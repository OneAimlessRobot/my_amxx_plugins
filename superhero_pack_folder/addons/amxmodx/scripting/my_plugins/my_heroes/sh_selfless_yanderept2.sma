public plugin_init()
{
	// Plugin Info
	register_plugin("SUPERHERO Selfless Yandere", "1.0", AUTHOR)
	// DO NOT EDIT THIS FILE TO CHANGE CVARS, USE THE SHCONFIG.CFG
	create_cvar("yandere_level", "8")
	create_cvar("yandere_degen_iter_period", "0.1")
	pcvar_base_dmg_mult = create_cvar("yandere_base_dmg_mult", "1.0")
	pcvar_dmg_pct_per_inc = create_cvar("yandere_dmg_pct_per_inc", "0.35")
	pcvar_explode_radius = create_cvar("yandere_explode_radius", "1")
	pcvar_explode_maxdamage = create_cvar("yandere_explode_maxdamage", "1")
	pcvar_psychosis_degen_pct = create_cvar("yandere_psychosis_degen_pct", "20.0")
	pcvar_psychosis_degen_health_threshold = create_cvar("yandere_psychosis_degen_health_threshold", "50.0")
	pcvar_trans_time = create_cvar("yandere_trans_time", "4.0")
	pcvar_base_extra_speed = create_cvar("yandere_base_extra_speed", "500")
	pcvar_speed_inc_per_inc = create_cvar("yandere_speed_inc_per_inc", "50")
	pcvar_curse_pct = create_cvar("yandere_angry_curse_pct", "0.5")
	pcvar_angry_speed = create_cvar("yandere_angry_speed", "1000")
	pcvar_angry_gravity = create_cvar("yandere_angry_gravity", "0.25")
	pcvar_angry_dmg_mult = create_cvar("yandere_angry_dmg_mult", "5.0")
	pcvar_angry_degen_pct = create_cvar("yandere_angry_degen_pct", "10.0")
	pcvar_overheal_hp_max = create_cvar("yandere_overheal_hp_max", "1000.0")
	pcvar_degen_health_extra_threshold = create_cvar("yandere_degen_health_extra_threshold", "500.0")
	pcvar_angry_hitheal_pct = create_cvar("yandere_angry_hitheal_pct", "1.0")
	pcvar_min_players = create_cvar("yandere_min_players", "6")
	gHeroID=shCreateHero(gHeroName, "YANDERE!", "Protect live teamates and avenge dead ones!", true, "yandere_level",true )
	

	sh_assign_hero_bit(gHeroID,SH_EXPLOSION_POWERS, true)

	sh_assign_hero_bit(gHeroID,hero_property_flags_id:53, true)

	sh_register_admin_only_hero(gHeroID,ADMIN_IMMUNITY,13,
				"No access was granted")


	static hero_name_arr[STRLEN_FOR_NAMES];
	arrayset(hero_name_arr,0,sizeof hero_name_arr)
	add(hero_name_arr,charsmax(hero_name_arr),gHeroName,charsmax(gHeroName))
	superheromod_help_link_hero(gHeroID, "Yandere: Help file","yandere_folder/","yandere_help_file.html",hero_name_arr)
	
	sh_register_superheromod_model(gHeroID,
								"models/player/yanderu/yanderu.mdl",
								"models/player/yanderu/yanderuT.mdl",
								"yanderu",
								"",
								"")
	sh_register_superheromod_model(gHeroID,
								"models/player/superyanderu/superyanderu.mdl",
								"models/player/superyanderu/superyanderuT.mdl",
								"superyanderu",
								"",
								"")
	sh_register_superheromod_model(gHeroID,
								"models/player/yanderu_psycho/yanderu_psycho.mdl",
								"models/player/yanderu_psycho/yanderu_psycho.mdl",
								"yanderu_psycho",
								"",
								"")

	register_event("Damage", "yandere_damage", "b", "2!0")
	register_event("CurWeapon", "weaponChange", "be", "1=1")

	RegisterHam(Ham_TraceAttack,"player","Yandere_ham_trace_damage",_,true)

	register_ham_hook_multiple(Ham_TraceAttack,
						full_entity_array_for_trace_attack,
						length_of_trace_attack_entity_array,
						"Yandere_Fire_Weapon",
						1,
						true)
	

	register_forward(FM_CmdStart, "yandere_angry_idle_checks")

	custom_dmg_id_senpai_avenger=sh_log_custom_damage_source(
								gHeroID,
								dmg_source_name_short_senpai_avenger,
								dmg_source_name_log_senpai_avenger,
								0)

	custom_dmg_id_drain=sh_log_custom_damage_source(
								gHeroID,
								dmg_source_name_short_drain,
								dmg_source_name_log_drain,
								0)

	custom_dmg_id_rage=sh_log_custom_damage_source(
								gHeroID,
								dmg_source_name_short_rage,
								dmg_source_name_log_rage,
								0)

	set_task( YANDERE_CYCLE_PERIOD, "yandere_loop", _, _, _, "b")

	init_hud_syncs()
	init_explosion_defaults()
}
public plugin_natives(){

	register_native("yandere_get_is_super","_yandere_get_is_super");
	register_native("yandere_get_hero_id","_yandere_get_hero_id");



}
public _yandere_get_hero_id(iPlugin,iParams){
	
	return gHeroID

}
public _yandere_get_is_super(iPlugin,iParams){
	new id= get_param(1)
	
	//return gSuperAngry[id]
	return Get_BitVar(gSuperAngryMask,id)

}

public yandere_angry_idle_checks(id, uc_handle){

	
	if(!sh_is_active()||sh_is_freezetime()){
		return FMRES_IGNORED
	}
	if(!is_user_alive(id)) return FMRES_IGNORED

	if(!sh_get_user_has_hero(id,gHeroID) ||!Get_BitVar(gSuperAngryMask,id)) return FMRES_IGNORED
	static butnprs

	Set_BitVar(gIdleAngryMask,id)
	butnprs =  get_uc(uc_handle, UC_Buttons);

	if (butnprs&IN_ATTACK || butnprs&IN_ATTACK2 || butnprs&IN_RELOAD || butnprs&IN_USE) UnSet_BitVar(gIdleAngryMask,id)

	if (butnprs&IN_JUMP) UnSet_BitVar(gIdleAngryMask,id)
	if (butnprs&IN_FORWARD || butnprs&IN_BACK || butnprs&IN_LEFT || butnprs&IN_RIGHT) UnSet_BitVar(gIdleAngryMask,id)
	if (butnprs&IN_MOVELEFT || butnprs&IN_MOVERIGHT) UnSet_BitVar(gIdleAngryMask,id)

	return FMRES_IGNORED

}
public Yandere_ham_trace_damage(Victim, Attacker, Float:Damage, Float:Direction[3], Ptr, DamageBits)
{
	if ( !sh_is_active() || !is_user_alive(Victim)||!is_user_alive(Attacker)){

		return HAM_IGNORED
	}

	new my_hitpoint_enum:the_hitpoint= my_hitpoint_enum:get_tr2(Ptr,TR_Hitgroup)

	return do_bleed_knife_attack(Victim,Attacker,gHeroID,15,65,
				sh_get_user_has_hero(Attacker,gHeroID) && Get_BitVar(gSuperAngryMask,Attacker),_,_,_,_,the_hitpoint)

	
}
