#define I_WANT_CONSTANTS
#define I_WANT_QUICK_CHECKS
#include "../my_include/superheromod.inc"
#include "../my_heroes/sh_aux_stuff/sh_aux_inc.inc"
#include "../my_heroes/sh_aux_stuff/sh_aux_stuff_natives_pt1.inc"
#include "../my_heroes/sh_aux_stuff/sh_aux_stuff_natives_pt2.inc"

// GLOBAL VARIABLES
new g_heroName[]="Thor"
new gHeroID
new g_spriteLightning

new gIsSearchingMask

new thors_hammer_wpn_id
new dmg_source_name_short_thors_hammer[SAFE_BUFFER_SIZE+1]="thors_hammer"
new dmg_source_name_long_thors_hammer[SAFE_BUFFER_SIZE+1]="thors_hammer"

new const gSoundThunder[] = "shmod/zeus_lightningbolt.wav"
new const gSoundSearch[] = "turret/tu_ping.wav"

new Float:thor_dmg_to_do,
	thor_cooldown

new gPcvarSearchTime
//----------------------------------------------------------------------------------------------
public plugin_init()
{
	// Plugin Info
	register_plugin("SUPERHERO Thor", "1.1", "TreDizzle")

	// DO NOT EDIT THIS FILE TO CHANGE CVARS, USE THE SHCONFIG.CFG
	register_cvar("thor_level", "8")
	register_cvar("thor_dmg_to_do", "190")
	register_cvar("thor_cooldown", "45")
	gPcvarSearchTime = register_cvar("thor_searchtime", "45")

	// FIRE THE EVENT TO CREATE THIS SUPERHERO!
	gHeroID=shCreateHero(g_heroName, "Thunder Bolt", "Strike Attackers with a Mighty Lightning Bolt from Thor's uru hammer Mjolnir.", true, "thor_level")
	
	sh_set_hero_bind(gHeroID)
	
	thors_hammer_wpn_id=sh_log_custom_damage_source(
								gHeroID,
								dmg_source_name_short_thors_hammer,
								dmg_source_name_long_thors_hammer,
								0)

	register_forward(FM_TraceLine,"fw_traceline");
	// EVENTS
	register_event("ResetHUD", "newSpawn", "b")
}
//----------------------------------------------------------------------------------------------
public plugin_precache()
{
	engfunc(EngFunc_PrecacheSound,gSoundThunder)
	engfunc(EngFunc_PrecacheSound,gSoundSearch)
	g_spriteLightning = engfunc(EngFunc_PrecacheModel,"sprites/lgtning.spr")
}
//----------------------------------------------------------------------------------------------
public newSpawn(id)
{
	sh_unset_cooldown_flag(id)
}
public fw_traceline(Float:v1[3],Float:v2[3],noMonsters,id)
{
	if ( !sh_is_inround()|| !sh_is_active() || !is_user_connected(id) ) return FMRES_IGNORED
	
	if ( !Get_BitVar(gIsSearchingMask,id)) return FMRES_IGNORED
	
	if ( !sh_user_has_hero(id,gHeroID)) return FMRES_IGNORED
	
	if(sh_get_cooldown_flag(id)){
		return FMRES_IGNORED
	}
	
	// get crosshair aim
	static iMyAim[3], Float:flMyAim[3];
	get_user_origin(id, iMyAim, 3);
	IVecFVec(iMyAim, flMyAim);
	
	// set crosshair aim
	set_tr(TR_vecEndPos, flMyAim);
	
	// get ent looking at
	static ent, body;
	get_user_aiming(id, ent, body);
	
	// if looking at something
	if( pev_valid(ent))
	{
		if(is_user_alive(ent)&&!sh_clients_are_same_team(ent,id)&&(ent!=id)){
			
			thor_thunder_damage(id, ent)
			
			
		}	
		
	}	
	return FMRES_IGNORED;
}
thor_thunder_damage(attacker, tg){


	emit_sound(attacker, CHAN_STATIC, gSoundThunder, 0.6, ATTN_NORM, 0, PITCH_NORM)
	emit_sound(tg, CHAN_STATIC, gSoundThunder, 0.4, ATTN_NORM, 0, PITCH_NORM)

	new extraDamage = floatround(thor_dmg_to_do )
	
	sh_extra_damage(tg, attacker, extraDamage, dmg_source_name_short_thors_hammer,
								_,_,_,_,_,_,
								SH_NEW_DMG_ENERGY_BLAST,
								thors_hammer_wpn_id)

	UnSet_BitVar(gIsSearchingMask,attacker)

	lightning_effect(attacker, tg, extraDamage)

	// make target feel it
	new alphanum = extraDamage * 2
	
	if ( alphanum > 200 ){
		alphanum = 200
	}
	else if ( alphanum < 40 ){
		alphanum = 40
	}
	
	setScreenFlash(tg, 255, 255, 224, 10, alphanum)
	sh_screenShake(tg, 12, 10, 14)
	if(!is_user_alive(tg)){

		new origin[3]
		get_user_origin(tg,origin)
		set_user_rendering(tg, kRenderFxFadeSlow, 255, 255, 255, kRenderTransColor, 4);
		anime_kill_fx(origin)

	}
	if ( is_user_alive(attacker) ) {
		// Set cooldown if Thor is still alive
		if (thor_cooldown > 0){
			ultimateTimer(attacker, float(thor_cooldown))
		}
	}
}

//----------------------------------------------------------------------------------------------
public sh_hero_key(id, heroID, key)
{
	if ( gHeroID != heroID || sh_is_freezetime() ) return
	if ( !is_user_alive(id) || !sh_user_has_hero(id,gHeroID)) return

	if ( Get_BitVar(gIsSearchingMask,id) ) return

	if ( key == SH_KEYDOWN )
	{
		// Let them know they already used their ultimate if they have
		if (sh_get_cooldown_flag(id) )
		{
			sh_sound_deny(id)
			return
		}

		Set_BitVar(gIsSearchingMask,id) 

		new parm[2]
		parm[0] = id
		parm[1] = get_pcvar_num(gPcvarSearchTime)
		thor_search(parm)
	}
}
//----------------------------------------------------------------------------------------------
public thor_search(parm[2])
{
	new id = parm[0]
	new timeLeft = parm[1]

	// Decrement our timer
	parm[1]--

	// User died or diconnected
	if ( !is_user_alive(id) || !sh_user_has_hero(id,gHeroID) )
	{
		UnSet_BitVar(gIsSearchingMask,id)
	}

	// This is the last "playing" of the sound, no target was found :/
	if ( timeLeft == 0 )
	{
		UnSet_BitVar(gIsSearchingMask,id)
	}

	// Then we need to play the sound + flash their icon!
	if ( Get_BitVar(gIsSearchingMask,id))
	{
		emit_sound(id, CHAN_STATIC, gSoundSearch, 1.0, ATTN_NORM, 0, PITCH_NORM)

		set_task(1.0, "thor_search", id, parm, 2)
	}
}
//----------------------------------------------------------------------------------------------
public plugin_cfg()
{
	loadCVARS();
}
//----------------------------------------------------------------------------------------------
public loadCVARS()
{
	thor_dmg_to_do=get_cvar_float("thor_dmg_to_do")
	thor_cooldown=get_cvar_num("thor_cooldown")

}
//----------------------------------------------------------------------------------------------
public lightning_effect(id, targetid, lineWidth)
{
	// Main Lightning
	message_begin(MSG_BROADCAST, SVC_TEMPENTITY)
	write_byte(8)				//TE_BEAMENTS
	write_short(id)			// start entity
	write_short(targetid)		// entity
	write_short(g_spriteLightning)	// model
	write_byte(0)			// starting frame
	write_byte(200)		// frame rate
	write_byte(15)			// life
	write_byte(lineWidth)	// line width
	write_byte(6)			// noise amplitude
	write_byte(255)		// r, g, b
	write_byte(255)		// r, g, b
	write_byte(224)		// r, g, b
	write_byte(125)		// brightness
	write_byte(0)			// scroll speed
	message_end()

	// Extra Lightning
	message_begin(MSG_BROADCAST, SVC_TEMPENTITY)
	write_byte(8)				//TE_BEAMENTS
	write_short(id)			// start entity
	write_short(targetid)		// entity
	write_short(g_spriteLightning)	// model
	write_byte(10)			// starting frame
	write_byte(200)		// frame rate
	write_byte(15)			// life
	write_byte(floatround(lineWidth/2.5))	// line width
	write_byte(18)			// noise amplitude
	write_byte(255)		// r, g, b
	write_byte(255)		// r, g, b
	write_byte(224)		// r, g, b
	write_byte(125)		// brightness
	write_byte(0)			// scroll speed
	message_end()
}
//----------------------------------------------------------------------------------------------